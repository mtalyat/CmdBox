{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run CmdBox (main.py)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Run CmdBox (No Debug Terminal)",
      "type": "node-terminal",
      "request": "launch",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe ${workspaceFolder}\\main.py"
    }
  ]
}
